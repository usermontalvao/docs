# Reverse proxy do serviço de conversão Syncfusion — MODO TÚNEL.
#
# Aqui o Caddy NÃO faz HTTPS: quem termina o TLS público é o túnel
# (Cloudflare Tunnel / ngrok / etc.). O Caddy só escuta HTTP numa porta interna
# fixa (:8080) e o docker-compose publica uma porta ALEATÓRIA no localhost, para
# a qual o túnel aponta. Nada de portas 80/443 nem Let's Encrypt.
#
# O Caddy continua útil por: CORS restrito, rate limit, limite de upload e por
# remover CORS duplicado do container.

{
	# Sem certificado próprio — o túnel cuida do HTTPS público.
	auto_https off
	# Necessário para o plugin caddy-ratelimit ter ordem definida no pipeline.
	order rate_limit before basicauth
}

# Escuta HTTP na porta interna 8080 (o compose mapeia a porta aleatória do host -> 8080).
:8080 {
	log

	# Headers de segurança em todas as respostas.
	header {
		-Server
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
	}

	# --- Allowlist de CORS ---------------------------------------------------
	# EDITE com os domínios reais do seu CRM. Origin fora da lista -> "" -> sem CORS.
	# (A Origin é sempre o domínio do CRM, não o domínio do túnel.)
	map {header.Origin} {allowed_origin} {
		https://jurius.com.br              "https://jurius.com.br"
		https://www.jurius.com.br          "https://www.jurius.com.br"
		https://crm-advogado.onrender.com  "https://crm-advogado.onrender.com"
		http://localhost:3000              "http://localhost:3000"
		# http://localhost:5173            "http://localhost:5173"   # use se o CRM local rodar no Vite padrão
		default                            ""
	}
	@allowed expression {allowed_origin} != ""

	# --- (OPCIONAL) Gate por API key -----------------------------------------
	# Enquanto DOCX_API_KEY estiver vazio no .env.server, este gate fica INATIVO.
	# Ao definir a chave, descomente E faça o frontend enviar o header X-Api-Key
	# (veja DEPLOY.md > Segurança). OPTIONS é isento (preflight não manda headers custom).
	# @unauthorized expression `"{$DOCX_API_KEY}" != "" && {http.request.method} != "OPTIONS" && {http.request.header.X-Api-Key} != "{$DOCX_API_KEY}"`
	# handle @unauthorized {
	# 	respond "Unauthorized" 401
	# }

	# --- Preflight (OPTIONS) -------------------------------------------------
	@preflight method OPTIONS
	handle @preflight {
		header @allowed {
			Access-Control-Allow-Origin "{allowed_origin}"
			Access-Control-Allow-Methods "GET, POST, OPTIONS"
			Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, X-Api-Key"
			Access-Control-Max-Age "86400"
			Vary "Origin"
		}
		respond 204
	}

	# --- Página de status (dashboard) na raiz --------------------------------
	@status {
		method GET
		path / /status /status/
	}
	handle @status {
		root * /srv
		rewrite * /status.html
		file_server
	}

	# --- Requisições reais (Import, etc.) ------------------------------------
	handle {
		# Rate limit por IP do cliente. ATENÇÃO: atrás de túnel, {remote_host} é
		# sempre o IP do túnel (127.0.0.1), o que limitaria TODO MUNDO junto.
		# Por isso usamos o IP real que o túnel encaminha no header:
		#   - Cloudflare Tunnel: troque para {http.request.header.Cf-Connecting-Ip}
		#   - ngrok / genérico:  {http.request.header.X-Forwarded-For}
		# Se o seu túnel não encaminhar o IP do cliente, remova este bloco
		# (senão vira um limite global de 120/min).
		rate_limit {
			zone docx_per_ip {
				key {http.request.header.X-Forwarded-For}
				events 120
				window 1m
			}
		}

		# Teto de tamanho do DOCX enviado (evita estourar memória do conversor).
		request_body {
			max_size 30MB
		}

		header @allowed {
			Access-Control-Allow-Origin "{allowed_origin}"
			Access-Control-Allow-Methods "GET, POST, OPTIONS"
			Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, X-Api-Key"
			Vary "Origin"
		}

		reverse_proxy word-processor-server:80 {
			header_down -Access-Control-Allow-Origin
			header_down -Access-Control-Allow-Methods
			header_down -Access-Control-Allow-Headers

			# DOCX grandes podem demorar.
			transport http {
				read_timeout 120s
				write_timeout 120s
			}
		}
	}
}
