# Reverse proxy do serviço de conversão Syncfusion.
# - HTTPS automático (Let's Encrypt) para {$DOCX_DOMAIN}
# - CORS restrito a uma allowlist (só reflete Origins conhecidas)
# - Rate limit por IP + limite de tamanho de upload (protege o endpoint aberto)
# - Gate OPCIONAL por X-Api-Key (comentado; ligue quando quiser)
#
# {$DOCX_DOMAIN}, {$ACME_EMAIL} e {$DOCX_API_KEY} vêm do .env.server (env_file no compose).

{
	email {$ACME_EMAIL}
	# Necessário para o plugin caddy-ratelimit ter ordem definida no pipeline.
	order rate_limit before basicauth
}

{$DOCX_DOMAIN} {
	log

	# Headers de segurança em todas as respostas.
	header {
		-Server
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
	}

	# --- Allowlist de CORS ---------------------------------------------------
	# EDITE com os domínios reais do seu CRM. Origin fora da lista -> "" -> sem CORS.
	map {header.Origin} {allowed_origin} {
		https://crm-advogado.onrender.com  "https://crm-advogado.onrender.com"
		https://app.seudominio.com.br      "https://app.seudominio.com.br"
		# http://localhost:5173            "http://localhost:5173"   # p/ testar local
		default                            ""
	}
	@allowed expression {allowed_origin} != ""

	# --- (OPCIONAL) Gate por API key -----------------------------------------
	# Enquanto DOCX_API_KEY estiver vazio no .env.server, este gate fica INATIVO
	# (não quebra o editor). Ao definir a chave, descomente as 3 linhas abaixo E
	# faça o frontend enviar o header X-Api-Key (veja DEPLOY.md > Segurança).
	# OPTIONS (preflight) é isento porque browsers não mandam headers custom nele.
	# @unauthorized expression `"{$DOCX_API_KEY}" != "" && {http.request.method} != "OPTIONS" && {http.request.header.X-Api-Key} != "{$DOCX_API_KEY}"`
	# handle @unauthorized {
	# 	respond "Unauthorized" 401
	# }

	# --- Preflight (OPTIONS) -------------------------------------------------
	@preflight method OPTIONS
	handle @preflight {
		header @allowed {
			Access-Control-Allow-Origin "{allowed_origin}"
			Access-Control-Allow-Methods "GET, POST, OPTIONS"
			Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, X-Api-Key"
			Access-Control-Max-Age "86400"
			Vary "Origin"
		}
		respond 204
	}

	# --- Requisições reais (Import, etc.) ------------------------------------
	handle {
		# Rate limit por IP de origem. 120 req/min é folgado p/ um escritório
		# atrás de um único IP (NAT) e ainda corta abuso. Ajuste se precisar.
		rate_limit {
			zone docx_per_ip {
				key {remote_host}
				events 120
				window 1m
			}
		}

		# Teto de tamanho do DOCX enviado (evita estourar memória do conversor).
		request_body {
			max_size 30MB
		}

		header @allowed {
			Access-Control-Allow-Origin "{allowed_origin}"
			Access-Control-Allow-Methods "GET, POST, OPTIONS"
			Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, X-Api-Key"
			Vary "Origin"
		}

		reverse_proxy word-processor-server:80 {
			# Remove CORS que o container porventura mande (evita header duplicado).
			header_down -Access-Control-Allow-Origin
			header_down -Access-Control-Allow-Methods
			header_down -Access-Control-Allow-Headers

			# DOCX grandes podem demorar.
			transport http {
				read_timeout 120s
				write_timeout 120s
			}
		}
	}
}
